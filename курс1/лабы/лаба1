#include <iostream>
#include <cmath>
struct stack1{
    double value;
    stack1* next;
};

bool proverkanacifri(char c){
    return c>='0'&&c<='9';
}

void dobavitstack(stack1*& top,double value){
    stack1* newnode=new stack1;
    newnode->value=value;
    newnode->next=top;
    top=newnode;
    
}
bool vzytiestack(stack1*& top,double& value){
    stack1* oldnode;
    if(top==nullptr){
        return false;
    }
    oldnode=top;
    value=oldnode->value;
    top=oldnode->next;
    delete oldnode;
    return true;
}
void udaleniestack(stack1*& top){
    double temp;
    while(top!=nullptr){
        vzytiestack(top,temp);
    }
}


int main(){
    stack1* stack=nullptr;
    char ch;
    double number;
    bool error=false;
    double a;
    double b;
    double result=0;
    std::cout<<"vvedite virachenie v postfiksnoi forme:\n";
    std::cout<<"NUCHO VSYO OBYZATELNO VVODIT CHEREZ PROBEL\n";


    std::cout<<"unarnii minus eto ~\n";
    
    while(std::cin.get(ch)){
        if(ch=='\n'){
            break;
        }
        if(ch==' ' || ch=='\t'){
            continue;
        }
        if((proverkanacifri(ch)|| ch=='.')|| ((ch=='+'||ch=='-')&&(proverkanacifri(std::cin.peek())||std::cin.peek()=='.'))){
            std::cin.putback(ch);
            std::cin>>number;
            if(!std::cin){
                std::cout<<"oshibka,nevernoe chislo\n";
                error=true;
                break;
            }
            dobavitstack(stack,number);
        }
        else if(ch=='~'){
            if(!vzytiestack(stack,a)){
                std::cout<<"oshibka,nedostatochno operandov dlya unarnogo minusa\n";
                error=true;
                break;
            }
            result=-a;
            dobavitstack(stack,result);
        }
        else if(ch=='+' || ch=='-' || ch=='*' || ch=='/' || ch=='^'){
            if(!vzytiestack(stack,b)){
                std::cout<<"oshibka,nedostatochno operandov\n";
                error=true;
                break;
            }
            if(!vzytiestack(stack,a)){
                std::cout<<"oshibka,nedostatochno operandov\n";
                error=true;
                break;
            }   
            if(ch=='+'){
                result=a+b;

            }
            else if(ch=='-'){
                result=a-b;
            }
            else if(ch=='*'){
                result=a*b;
            }
            else if(ch=='/'){
                if(b==0){
                    std::cout<<"oshibka.nelzya delit na nol\n";
                    error=true;
                    break;
                }
                result=a/b;
            }
            else if(ch=='^'){
                result=pow(a,b);
            }
            dobavitstack(stack,result);
        }
        else{
            std::cout<<"oshibka.neizvestnii symbol\n";
            error=true;
            break;
        }
    }
    if(!error){
        if(!vzytiestack(stack,result)){
            std::cout<<"virachenie pusto\n";
            error=true;
        }
        else if(stack!=nullptr){
            std::cout<<"sohibka,v steke est symboli\n";
            error=true;
        }
        else{
            std::cout<<"resultat: "<<result<<"\n";
        }
    }
    udaleniestack(stack);


    if(error){
        return 1;
    }

        




    


    return 0;
}
